/* ========================================
   TABLET RESPONSIVE DESIGN - 1024px
   ======================================== */

@media (max-width: 1024px) and (min-width: 481px) {
    .nav {
        padding: 24px 32px;
    }

    .navLabels {
        gap: 32px;
    }

    .div {
        font-size: 14px;
    }

    .hero {
        padding: 80px 32px;
        gap: 60px;
    }

    .intro {
        width: 100%;
        max-width: 100%;
        height: auto;
        padding: 0px 0px 60px;
    }

    .representativeProject {
        font-size: 20px;
